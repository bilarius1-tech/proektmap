generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  passwordHash String?   @default("")
  xp        Int      @default(0)
  level     String   @default("novice")
  role      String   @default("user")
  subscription String   @default("free")
  streak    Int      @default(0)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  avatar     String   @default("")
  bio        String   @default("")
  projects  Project[]
  favorites Favorite[]
  posts       BlogPost[]
  @@map("users")
}

model Blueprint {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  icon        String   @default("Globe")
  difficulty  String   @default("easy")
  totalXp     Int      @default(0)
  totalDecisions Int   @default(0)
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  stages      BlueprintStage[]
  projects    Project[]
  @@map("blueprints")
}

model Stage {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  icon        String   @default("Zap")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  decisions   Decision[]
  blueprints  BlueprintStage[]
  @@map("stages")
}

model BlueprintStage {
  id          String   @id @default(uuid())
  blueprintId String
  stageId     String
  sortOrder   Int      @default(0)
  blueprint Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  stage     Stage     @relation(fields: [stageId], references: [id], onDelete: Cascade)
  @@unique([blueprintId, stageId])
  @@map("blueprint_stages")
}

model Decision {
  id            String   @id @default(uuid())
  stageId       String
  title         String
  slug          String   @unique
  problem       String
  why           String   @default("")
  recommended   String   @default("")
  content       String   @default("")
  tradeoffs     String   @default("")
  whenNotUse    String   @default("")
  mistakes      String   @default("")
  context       String   @default("")
  constraints   String   @default("")
  validation    String   @default("")
  iteration     String   @default("")
  difficulty    String   @default("easy")
  xpReward      Int      @default(15)
  timeEstimate  String   @default("15 мин")
  promptTitle   String?
  promptTemplate String?
  promptContext  String?
  videos       Json      @default("[]")
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stage          Stage              @relation(fields: [stageId], references: [id], onDelete: Cascade)
  artifacts      Artifact[]
  checks         CheckItem[]
  alternatives   DecisionAlternative[]
  relationsFrom  DecisionRelation[] @relation("from")
  relationsTo    DecisionRelation[] @relation("to")
  progress       ProjectDecision[]
  skills        DecisionSkill[]
  favorites     Favorite[]
  @@map("decisions")
}

model DecisionAlternative {
  id         String   @id @default(uuid())
  decisionId String
  title      String
  description String?
  pros       String   @default("")
  cons       String   @default("")
  sortOrder  Int      @default(0)
  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  @@map("decision_alternatives")
}

model DecisionRelation {
  id              String   @id @default(uuid())
  fromDecisionId  String
  toDecisionId    String
  relationType    String
  note            String?
  fromDecision Decision @relation("from", fields: [fromDecisionId], references: [id], onDelete: Cascade)
  toDecision   Decision @relation("to", fields: [toDecisionId], references: [id], onDelete: Cascade)
  @@unique([fromDecisionId, toDecisionId, relationType])
  @@map("decision_relations")
}

model Artifact {
  id         String   @id @default(uuid())
  decisionId String
  title      String
  description String?
  template   String?
  sortOrder  Int      @default(0)
  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  @@map("artifacts")
}

model CheckItem {
  id         String   @id @default(uuid())
  decisionId String
  title      String
  sortOrder  Int      @default(0)
  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  @@map("check_items")
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  blueprintId String
  progress    Int      @default(0)
  name        String   @default("")
  description String   @default("")
  domain      String   @default("")
  stack       String   @default("")
  niche       String   @default("")
  colors      String   @default("")
  goals       String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  blueprint Blueprint         @relation(fields: [blueprintId], references: [id])
  decisions ProjectDecision[]
  @@map("projects")
}

model ProjectDecision {
  id          String    @id @default(uuid())
  projectId   String
  decisionId  String
  status      String    @default("pending")
  notes       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  @@unique([projectId, decisionId])
  userChoice  String   @default("")
  @@map("project_decisions")
}

model MenuItem {
  id        String   @id @default(uuid())
  label     String
  href      String
  parentId  String?
  sortOrder Int      @default(0)
  location  String   @default("header")
  isActive  Boolean  @default(true)
  icon      String?
  createdAt DateTime @default(now())
  
  parent   MenuItem?  @relation("MenuChildren", fields: [parentId], references: [id])
  children MenuItem[] @relation("MenuChildren")

  @@map("menu_items")
}

model Skill {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @default("")
  
  // SKILL.md — основной контент
  skillMd     String   @default("")
  
  // Вспомогательные файлы (паттерн vibe-coding-cn)
  assetsPath  String?  // путь к assets/
  scriptsPath String?  // путь к scripts/
  refsPath    String?  // путь к references/
  
  difficulty  String   @default("easy")
  xpReward    Int      @default(15)
  timeEstimate String  @default("15 мин")
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Промпты (как у Decision)
  promptTitle    String?
  promptTemplate String?

  // Связи
  decisions DecisionSkill[]
  
  @@map("skills")
}

model DecisionSkill {
  id         String   @id @default(uuid())
  decisionId String
  skillId    String
  sortOrder  Int      @default(0)
  
  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  @@unique([decisionId, skillId])
  @@map("decision_skills")
}

model ReferralLink {
  id          String   @id @default(uuid())
  service     String   @unique
  label       String
  url         String
  description String   @default("")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("referral_links")
}

model SiteSettings {
  id        String   @id @default("main")
  proPrice  Int      @default(300)
  yookassaShopId    String   @default("")
  yookassaSecretKey String   @default("")
  deepseekApiKey     String   @default("")
  openrouterApiKey   String   @default("")
  openrouterModel    String   @default("openai/gpt-4o-mini")
  deepseekModel      String   @default("deepseek-chat")
  autoPublishEnabled Boolean  @default(false)
  autoPublishHour    Int      @default(9)
  updatedAt DateTime @updatedAt
  @@map("site_settings")
}

model AIModel {
  id          String   @id @default(uuid())
  name        String   @unique   // "Claude Opus 4.8"
  provider    String             // "Anthropic", "OpenAI", "DeepSeek"...
  category    String             // "coding", "reasoning", "vision"
  
  // Ratings (1-10)
  codeRating      Int    @default(7)
  siteRating      Int    @default(7)
  agentRating     Int    @default(7)
  speedRating     Int    @default(7)
  
  // Pricing
  pricePerMillion  Int    @default(0)  // ₽ за 1M токенов
  contextWindow    Int    @default(128000)
  
  // Recommendations
  bestFor     String  @default("")  // "Лендинг, SaaS, Telegram Bot"
  notFor      String  @default("")  // "Тяжёлая аналитика"
  
  isPublished Boolean @default(true)
  sortOrder   Int     @default(0)
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_models")
}

model Prompt {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  category    String
  description String?
  content     String
  tags        String   @default("")
  useCount    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("prompts")
}

model PromptVariable {
  id          String   @id @default(uuid())
  name        String   @unique
  label       String
  description String
  example     String   @default("")
  category    String   @default("общее")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("prompt_variables")
}

model PromptCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  icon        String   @default("folder")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("prompt_categories")
}

model Favorite {
  id          String   @id @default(uuid())
  userId      String
  decisionId  String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  decision    Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  @@unique([userId, decisionId])
  @@map("favorites")
}

model BlogCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String    @default("")
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  posts       BlogPost[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@map("blog_categories")
}

model BlogPost {
  id            String    @id @default(uuid())
  title         String
  slug          String    @unique
  content       String
  excerpt       String    @default("")
  coverImage    String    @default("")
  status        String    @default("draft")
  authorId      String
  categoryId    String?
  tags          String    @default("")
  viewCount     Int       @default(0)
  aiGenerated   Boolean   @default(false)
  aiModel       String    @default("")
  metaTitle     String    @default("")
  metaDesc      String    @default("")
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        User           @relation(fields: [authorId], references: [id])
  category      BlogCategory?  @relation(fields: [categoryId], references: [id])
  comments      BlogComment[]
  @@map("blog_posts")
}

model BlogComment {
  id          String    @id @default(uuid())
  postId      String
  authorName  String
  authorEmail String    @default("")
  content     String
  status      String    @default("pending")
  parentId    String?
  rating      Int       @default(0)
  createdAt   DateTime  @default(now())
  post        BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent      BlogComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies     BlogComment[] @relation("CommentReplies")
  @@map("blog_comments")
}

model AutoPublish {
  id          String    @id @default(uuid())
  topic       String
  category    String    @default("")
  model       String    @default("openrouter")
  schedule    String    @default("0 9 * * *")
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@map("auto_publish")
}

model BlogFeed {
  id          String    @id @default(uuid())
  name        String
  url         String
  type        String    @default("rss")
  category    String    @default("AI")
  language    String    @default("en")
  isActive    Boolean   @default(true)
  lastFetched DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@map("blog_feeds")
}
